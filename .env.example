# === Required API Keys ===
# Free-tier keys are sufficient for eval and demo usage.
# The pipeline degrades gracefully: analyzers without keys return
# confidence=0.0 and are excluded from scoring (no false signal).
VIRUSTOTAL_API_KEY=           # https://www.virustotal.com/gui/join-us (500 req/day free)
URLSCAN_API_KEY=              # https://urlscan.io/user/signup (5,000 req/day free)
ABUSEIPDB_API_KEY=            # https://www.abuseipdb.com/register (1,000 req/day free)
GOOGLE_SAFE_BROWSING_API_KEY= # https://console.cloud.google.com (10,000 req/day free)

# === Sandbox (pick one, comment out the rest) ===
SANDBOX_PROVIDER=hybrid_analysis
HYBRID_ANALYSIS_API_KEY=      # https://www.hybrid-analysis.com/signup
# ANYRUN_API_KEY=             # https://any.run
# JOESANDBOX_API_KEY=         # https://www.joesandbox.com

# === Optional: LLM for intent classification ===
# Without an LLM key, nlp_intent falls back to sklearn TF-IDF.
# The LLM path improves BEC/social-engineering detection but is not
# required for the pipeline to run.
# Cost-first production recommendation: use DeepSeek for Starter/Pro/Business.
# Re-benchmark on real redacted samples before any Enterprise model override.
# Keep Anthropic/OpenAI/Gemini only when evals justify the extra API cost.
# Providers:
# - anthropic: uses ANTHROPIC_API_KEY and optional LLM_MODEL
# - deepseek: uses DEEPSEEK_API_KEY, defaults to deepseek-v4-flash
# - moonshot/kimi: uses MOONSHOT_API_KEY, defaults to kimi-k2.6
# - gemini: uses GEMINI_API_KEY, defaults to gemini-3-flash-preview
# - openai/openai_compatible: uses OPENAI_API_KEY or LLM_API_KEY,
#   defaults to gpt-5.4-mini; set LLM_MODEL=gpt-5.5 for flagship evals
LLM_PROVIDER=deepseek
LLM_MODEL=
LLM_API_BASE=
LLM_API_KEY=
ANTHROPIC_API_KEY=            # https://console.anthropic.com
DEEPSEEK_API_KEY=             # https://platform.deepseek.com
MOONSHOT_API_KEY=             # https://platform.moonshot.ai
GEMINI_API_KEY=               # https://aistudio.google.com/app/apikey
# OPENAI_API_KEY=

# === IMAP (for email ingestion -- optional for manual/eval usage) ===
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# === Orchestrator Config ===
MAX_CONCURRENT_ANALYZERS=10
URL_DETONATION_TIMEOUT_SECONDS=30
ANALYSIS_PIPELINE_TIMEOUT_SECONDS=120
# Reject manual/API email uploads larger than this before parsing.
MAX_EMAIL_UPLOAD_BYTES=10485760
FEEDBACK_DB_PATH=data/feedback.db
LOG_LEVEL=INFO
# docker-compose sets this automatically to the isolated browser-sandbox service.
# Leave blank for local Playwright launch outside Docker.
PLAYWRIGHT_WS_ENDPOINT=

# Optional. If present, payment_fraud reports an ML sidecar beside the rules decision.
PAYMENT_DECISION_MODEL_PATH=models/payment_classifier/payment_decision_model.joblib
# Local MCP/agent tool hard limits.
AGENT_PAYMENT_MAX_EMAIL_BYTES=10485760
PAYMENT_FIREWALL_TOOL_TIMEOUT_MS=60000
PAYMENT_FIREWALL_MAX_TOOL_OUTPUT_BYTES=2097152

# === Dashboard ===
DASHBOARD_PORT=8000
# Generate a random token: python -c "import secrets; print(secrets.token_urlsafe(32))"
ANALYST_API_TOKEN=
# Optional public sample-only demo at /demo. This never enables live analysis,
# mailbox access, paid API-backed checks, feedback learning, or account management.
PUBLIC_DEMO_MODE=false
# Browser session lifetime in seconds (default: 8 hours).
SESSION_MAX_AGE_SECONDS=28800

# === SaaS Accounts (normal user login) ===
# Generate a random secret:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SAAS_SESSION_SECRET=
SAAS_DB_PATH=data/saas.db
# Keep false until privacy terms, retention, support, and abuse controls are ready.
SAAS_PUBLIC_SIGNUP_ENABLED=false
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# === Transactional Email (Zoho Mail compatible password reset) ===
# Zoho Mail supports smtp.zoho.com with port 465 + SSL, or port 587 + STARTTLS.
# If Zoho 2FA is enabled, use a Zoho application-specific password here.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PhishAnalyze
SMTP_USE_SSL=false
SMTP_STARTTLS=true

# Runtime retention for results, alerts, feedback, and sender profiles.
DATA_RETENTION_DAYS=30

# === Public hostnames ===
# Point both hostnames at the same service/tunnel. The app keeps the two brands
# separated with host-aware redirects.
PHISHANALYZE_PUBLIC_URL=https://phishanalyze.mdpstudio.com.au
PAYSHIELD_PUBLIC_URL=https://payshield.mdpstudio.com.au

# === Stripe Billing (SaaS subscriptions) ===
# Use Stripe Billing + Checkout Sessions for subscriptions. Register
# https://your-domain/api/stripe/webhook in Stripe and paste its signing secret.
# PUBLIC_BASE_URL is a fallback URL builder; Checkout/Portal returns use
# PAYSHIELD_PUBLIC_URL when it is set.
PUBLIC_BASE_URL=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_STARTER_YEARLY=
STRIPE_PRICE_PRO=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_BUSINESS_YEARLY=
# Stripe Checkout can present eligible local currencies while these Prices
# remain AUD-backed. Set false if Stripe rejects adaptive pricing for the account.
STRIPE_ADAPTIVE_PRICING_ENABLED=true

# Generate before connecting mailbox accounts and keep stable across rebuilds.
# If this changes, saved mailbox passwords must be reconnected.
# python -c "import secrets; print(secrets.token_urlsafe(48))"
ACCOUNTS_ENCRYPTION_KEY=

# === Cloudflare DNS Automation (for scripts/cf-dns-add.sh) ===
# Get your API token: https://dash.cloudflare.com/profile/api-tokens
# Required permission: Zone > DNS > Edit
CF_API_TOKEN=
CF_ZONE_ID=01b510a4f9a91643bb0718bf2d59e305
CF_DOMAIN=mdpstudio.com.au
