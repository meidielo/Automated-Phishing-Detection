# === Production Environment (Indonesia PC via Cloudflare Tunnel) ===
# Copy this to .env on the deployment machine and fill in your keys.
# NEVER commit this file with real values.

# --- Threat Intel API Keys (all free tier) ---
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
URLSCAN_API_KEY=
ABUSEIPDB_API_KEY=

# --- Sandbox (optional: only needed for attachment analysis) ---
SANDBOX_PROVIDER=hybrid_analysis
HYBRID_ANALYSIS_API_KEY=

# --- LLM (NLP intent classification) ---
# Cost-first default. Use DeepSeek for Starter/Pro/Business. Re-benchmark on
# real redacted samples before any Enterprise model override. Use Anthropic,
# Gemini, or OpenAI only when evals justify the extra API cost.
LLM_PROVIDER=deepseek
LLM_MODEL=
LLM_API_BASE=
LLM_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
GEMINI_API_KEY=

# --- Auth (REQUIRED for public deployment) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ANALYST_API_TOKEN=
# Optional public sample-only demo at /demo. Keep analyst token configured:
# this does not expose live analysis, mailbox data, paid API usage, feedback
# learning, or account management.
PUBLIC_DEMO_MODE=false
# Browser session lifetime in seconds (default: 8 hours).
SESSION_MAX_AGE_SECONDS=28800

# --- SaaS user accounts ---
# Generate separately from ANALYST_API_TOKEN:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SAAS_SESSION_SECRET=
SAAS_DB_PATH=data/saas.db
# Production signup is open for public PhishAnalyze and PayShield accounts.
SAAS_PUBLIC_SIGNUP_ENABLED=true
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# --- Transactional Email (password reset) ---
# Preferred: Zoho Mail API direct send.
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ACCOUNTS_BASE=https://accounts.zoho.com.au
ZOHO_ACCOUNT_ID=
ZOHO_FROM=
ZOHO_API_BASE=https://mail.zoho.com.au
ZOHO_ENABLE_DIRECT_SEND=true

# Optional fallback: SMTP.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PhishAnalyze
SMTP_USE_SSL=false
SMTP_STARTTLS=true

# --- Pipeline tuning ---
MAX_CONCURRENT_ANALYZERS=5
URL_DETONATION_TIMEOUT_SECONDS=30
ANALYSIS_PIPELINE_TIMEOUT_SECONDS=120
FEEDBACK_DB_PATH=data/feedback.db
LOG_LEVEL=WARNING
DASHBOARD_PORT=8000
PLAYWRIGHT_WS_ENDPOINT=ws://browser-sandbox:3000/
DATA_RETENTION_DAYS=30

# --- Public hostnames ---
# Point both hostnames at the same Cloudflare Tunnel service. The app keeps the
# two brands separated with host-aware redirects.
PHISHANALYZE_PUBLIC_URL=https://phishanalyze.mdpstudio.com.au
PAYSHIELD_PUBLIC_URL=https://payshield.mdpstudio.com.au

# --- Stripe Billing (SaaS subscriptions) ---
# Register https://phishanalyze.mdpstudio.com.au/api/stripe/webhook or
# https://payshield.mdpstudio.com.au/api/stripe/webhook in Stripe and paste the
# endpoint signing secret here. Checkout/Portal returns use PAYSHIELD_PUBLIC_URL.
PUBLIC_BASE_URL=https://phishanalyze.mdpstudio.com.au
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_1TSfNdJWX1cX2E7b5I0WEwSJ
STRIPE_PRICE_STARTER_YEARLY=price_1TSfNeJWX1cX2E7bFeyAwIwM
STRIPE_PRICE_PRO=price_1TSfNfJWX1cX2E7bCsh9cRx9
STRIPE_PRICE_PRO_YEARLY=price_1TSfNhJWX1cX2E7bdL6BOjCS
STRIPE_PRICE_BUSINESS=price_1TSfNjJWX1cX2E7bVNW7dpAF
STRIPE_PRICE_BUSINESS_YEARLY=price_1TSfNmJWX1cX2E7bGjtWb8vs
STRIPE_ADAPTIVE_PRICING_ENABLED=true

# --- Optional monitored mailbox storage ---
# Set before connecting accounts and keep stable across rebuilds.
# If this changes, saved mailbox passwords must be reconnected once.
# IMAP_HOST=
# IMAP_USER=
# IMAP_PASSWORD=
# ACCOUNTS_ENCRYPTION_KEY=
# OPENAI_API_KEY=
