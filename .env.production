# === Production Environment (Indonesia PC via Cloudflare Tunnel) ===
# Copy this to .env on the deployment machine and fill in your keys.
# NEVER commit this file with real values.

# --- Threat Intel API Keys (all free tier) ---
VIRUSTOTAL_API_KEY=
GOOGLE_SAFE_BROWSING_API_KEY=
URLSCAN_API_KEY=
ABUSEIPDB_API_KEY=

# --- Sandbox (optional: only needed for attachment analysis) ---
SANDBOX_PROVIDER=hybrid_analysis
HYBRID_ANALYSIS_API_KEY=

# --- LLM (NLP intent classification) ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=

# --- Auth (REQUIRED for public deployment) ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
ANALYST_API_TOKEN=
# Optional public sample-only demo at /demo. Keep analyst token configured:
# this does not expose live analysis, mailbox data, paid API usage, feedback
# learning, or account management.
PUBLIC_DEMO_MODE=false
# Browser session lifetime in seconds (default: 8 hours).
SESSION_MAX_AGE_SECONDS=28800

# --- SaaS user accounts ---
# Generate separately from ANALYST_API_TOKEN:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SAAS_SESSION_SECRET=
SAAS_DB_PATH=data/saas.db
# Keep disabled until the deployment is ready to accept visitor email uploads.
SAAS_PUBLIC_SIGNUP_ENABLED=false

# --- Pipeline tuning ---
MAX_CONCURRENT_ANALYZERS=5
URL_DETONATION_TIMEOUT_SECONDS=30
ANALYSIS_PIPELINE_TIMEOUT_SECONDS=120
FEEDBACK_DB_PATH=data/feedback.db
LOG_LEVEL=WARNING
DASHBOARD_PORT=8000
PLAYWRIGHT_WS_ENDPOINT=ws://browser-sandbox:3000/
DATA_RETENTION_DAYS=30

# --- Stripe Billing (SaaS subscriptions) ---
# Register https://phishanalyze.mdpstudio.com.au/api/stripe/webhook in Stripe
# and paste the endpoint signing secret here.
PUBLIC_BASE_URL=https://phishanalyze.mdpstudio.com.au
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# --- Not used in production (no IMAP monitoring) ---
# IMAP_HOST=
# IMAP_USER=
# IMAP_PASSWORD=
# ACCOUNTS_ENCRYPTION_KEY=
# OPENAI_API_KEY=
